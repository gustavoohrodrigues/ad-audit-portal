# ==================================================
# AD-Audit-Portal — arquivo de exemplo de ambiente
# Copie para .env e ajuste. NUNCA versione o .env real.
# Gere chaves com:  openssl rand -hex 48
# ==================================================

# ==================================================
# APLICAÇÃO
# ==================================================
APP_NAME=AD-Audit-Portal
APP_ENV=production
APP_DEBUG=false
APP_URL=https://ad-audit.seudominio.local
APP_TIMEZONE=America/Sao_Paulo
APP_SECRET_KEY=GERAR_UMA_CHAVE_ALEATORIA_FORTE
JWT_SECRET_KEY=GERAR_OUTRA_CHAVE_ALEATORIA_FORTE
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================================================
# FRONTEND E CORS
# ==================================================
FRONTEND_URL=https://ad-audit.seudominio.local
CORS_ALLOWED_ORIGINS=https://ad-audit.seudominio.local
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ==================================================
# POSTGRESQL
# ==================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ad_audit
POSTGRES_USER=ad_audit_app
POSTGRES_PASSWORD=ALTERAR_PARA_UMA_SENHA_FORTE
DATABASE_URL=postgresql+psycopg://ad_audit_app:ALTERAR_PARA_UMA_SENHA_FORTE@postgres:5432/ad_audit

# ==================================================
# REDIS
# ==================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ALTERAR_PARA_UMA_SENHA_FORTE
REDIS_URL=redis://:ALTERAR_PARA_UMA_SENHA_FORTE@redis:6379/0
CELERY_BROKER_URL=redis://:ALTERAR_PARA_UMA_SENHA_FORTE@redis:6379/1
CELERY_RESULT_BACKEND=redis://:ALTERAR_PARA_UMA_SENHA_FORTE@redis:6379/2

# ==================================================
# ACTIVE DIRECTORY / LDAP (SOMENTE LEITURA)
# ==================================================
AD_ENABLED=true
AD_DOMAIN=empresa.local
AD_NETBIOS_DOMAIN=EMPRESA
AD_BASE_DN=DC=empresa,DC=local
AD_LDAP_URI=ldaps://dc01.empresa.local:636
AD_LDAP_FALLBACK_URI=ldaps://dc02.empresa.local:636
AD_LDAP_USE_SSL=true
AD_LDAP_TLS_VERIFY=true
AD_LDAP_CA_CERT_PATH=/run/secrets/ad_ca_certificate.pem
AD_LDAP_TIMEOUT_SECONDS=10
AD_LDAP_PAGE_SIZE=500

# Conta de serviço somente leitura no AD.
AD_BIND_USERNAME=svc_ad_audit@empresa.local
AD_BIND_PASSWORD=ALTERAR_PARA_SENHA_FORTE
AD_BIND_DN=CN=svc_ad_audit,OU=Service Accounts,DC=empresa,DC=local

# Filtros / bases de busca LDAP
AD_USERS_SEARCH_BASE=OU=Usuarios,DC=empresa,DC=local
AD_COMPUTERS_SEARCH_BASE=OU=Computadores,DC=empresa,DC=local
AD_GROUPS_SEARCH_BASE=OU=Grupos,DC=empresa,DC=local
AD_SERVICE_ACCOUNTS_SEARCH_BASE=OU=Service Accounts,DC=empresa,DC=local
AD_SYNC_ENABLED=true
AD_SYNC_INTERVAL_MINUTES=60
# Modo de sincronização: full | incremental (incremental usa uSNChanged)
AD_SYNC_MODE=full
AD_SYNC_USN_CHANGED_ENABLED=true

# ==================================================
# AUTENTICAÇÃO DA APLICAÇÃO
# ==================================================
AUTH_PROVIDER=ldap
AUTH_LDAP_ENABLED=true
AUTH_LDAP_URI=ldaps://dc01.empresa.local:636
AUTH_LDAP_BASE_DN=DC=empresa,DC=local
AUTH_LDAP_USER_SEARCH_BASE=OU=Usuarios,DC=empresa,DC=local
AUTH_LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName={username}))
AUTH_LDAP_GROUP_SEARCH_BASE=OU=Grupos,DC=empresa,DC=local

# Grupos AD que definem o RBAC da aplicação
AUTH_GROUP_VIEWERS=GG_AD_AUDIT_VIEWERS
AUTH_GROUP_HELPDESK=GG_AD_AUDIT_HELPDESK
AUTH_GROUP_SECURITY=GG_AD_AUDIT_SECURITY
AUTH_GROUP_ADMINS=GG_AD_AUDIT_ADMINS

# ==================================================
# COLETA DE EVENTOS
# ==================================================
EVENT_COLLECTOR_MODE=wef
EVENT_COLLECTOR_ENABLED=true
EVENT_RETENTION_DAYS=90
EVENT_RAW_RETENTION_DAYS=14
EVENT_BATCH_SIZE=500
EVENT_POLL_INTERVAL_SECONDS=60

# ---- Política de armazenamento (CONTROLE DE VOLUME/TAMANHO DO BANCO) ----
# O maior consumo vem do JSON bruto e dos eventos de "ruído" (autenticação de
# alto volume). Estas variáveis evitam o crescimento descontrolado do banco.
#
# Guardar o JSON bruto de TODOS os eventos? false = só dos importantes (abaixo).
EVENT_STORE_RAW=false
# Tipos cujo JSON bruto é preservado mesmo com EVENT_STORE_RAW=false.
EVENT_STORE_RAW_TYPES=account_lockout,password_reset,password_change,user_created,user_deleted,group_member_added,group_member_removed,account_disabled,account_enabled,account_changed,account_renamed,account_unlocked,service_installed,ds_object_modified,ds_object_created,ds_object_deleted,special_privileges_assigned
# Tipos ignorados por completo na ingestão (nem são gravados). successful_logon
# (4624) é o maior gerador de volume e não é consumido por nenhuma tela.
EVENT_DROP_TYPES=successful_logon
# Eventos de ruído (alto volume) expurgados mais cedo que os demais.
EVENT_NOISE_RETENTION_DAYS=14
EVENT_NOISE_TYPES=failed_logon,ntlm_validation,kerberos_preauth_failed,successful_logon,kerberos_service_ticket,kerberos_tgt_request,kerberos_ticket_renewed,kerberos_service_ticket_failed,explicit_credential_logon

# Modos aceitos: wef, winrm, elastic, wazuh, graylog, splunk, api
WEF_ENABLED=true
WEF_HOST=wef-collector.empresa.local
WEF_PORT=5985
WEF_LOG_NAME=ForwardedEvents

# Uso opcional de WinRM, preferencialmente desabilitado quando WEF estiver ativo
WINRM_ENABLED=false
WINRM_USERNAME=svc_ad_event_reader@empresa.local
WINRM_PASSWORD=ALTERAR_PARA_SENHA_FORTE
WINRM_TRANSPORT=ntlm
WINRM_USE_SSL=true
WINRM_PORT=5986
WINRM_VERIFY_TLS=true
WINRM_DOMAIN_CONTROLLERS=dc01.empresa.local,dc02.empresa.local

# Conectores SIEM alternativos (usados conforme EVENT_COLLECTOR_MODE)
ELASTIC_URL=https://elastic.empresa.local:9200
ELASTIC_API_KEY=
ELASTIC_INDEX=winlogbeat-*
WAZUH_API_URL=https://wazuh.empresa.local:55000
WAZUH_API_USER=
WAZUH_API_PASSWORD=
GRAYLOG_API_URL=https://graylog.empresa.local/api
GRAYLOG_API_TOKEN=
SPLUNK_API_URL=https://splunk.empresa.local:8089
SPLUNK_API_TOKEN=

# ==================================================
# EVENTOS E CORRELAÇÃO
# ==================================================
EVENT_IDS_ACCOUNT_LOCKOUT=4740
EVENT_IDS_PASSWORD_CHANGE=4723
EVENT_IDS_PASSWORD_RESET=4724
EVENT_IDS_ACCOUNT_CHANGED=4738
EVENT_IDS_ACCOUNT_ENABLED=4722
EVENT_IDS_ACCOUNT_DISABLED=4725
EVENT_IDS_ACCOUNT_UNLOCKED=4767
EVENT_IDS_ACCOUNT_RENAMED=4781
EVENT_IDS_USER_CREATED=4720
EVENT_IDS_USER_DELETED=4726
EVENT_IDS_GROUP_MEMBER_ADDED=4728,4732,4756
EVENT_IDS_GROUP_MEMBER_REMOVED=4729,4733,4757
EVENT_IDS_FAILED_LOGON=4625,4771,4776
EVENT_IDS_SUCCESSFUL_LOGON=4624
EVENT_IDS_DIRECTORY_SERVICE_CHANGES=5136,5137,5141

LOCKOUT_CORRELATION_WINDOW_MINUTES=30
FAILED_LOGON_CORRELATION_WINDOW_MINUTES=15
RECURRING_LOCKOUT_THRESHOLD=3
RECURRING_LOCKOUT_WINDOW_HOURS=24

# ==================================================
# RISCO E CONTAS PRIVILEGIADAS
# ==================================================
RISK_SCORING_ENABLED=true
RISK_ALERT_THRESHOLD_MEDIUM=50
RISK_ALERT_THRESHOLD_HIGH=75
RISK_ALERT_THRESHOLD_CRITICAL=90
BUSINESS_HOURS_START=8
BUSINESS_HOURS_END=18

PRIVILEGED_GROUPS=Domain Admins,Enterprise Admins,Schema Admins,Administrators,Account Operators,Backup Operators,Server Operators,Print Operators
CRITICAL_USERS=administrator,krbtgt,svc_backup,svc_veeam
CRITICAL_OUS=OU=Service Accounts,DC=empresa,DC=local;OU=Administradores,DC=empresa,DC=local

INACTIVE_ACCOUNT_DAYS=90
PASSWORD_NEVER_EXPIRES_ALERT=true
PASSWORD_NOT_REQUIRED_ALERT=true
SID_HISTORY_ALERT=true
DELEGATION_ALERT=true
SPN_CHANGE_ALERT=true
ADMIN_COUNT_ALERT=true

# ==================================================
# ALERTAS E INTEGRAÇÕES
# ==================================================
ALERTS_ENABLED=true
ALERT_DEDUP_WINDOW_MINUTES=60
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.empresa.local
SMTP_PORT=587
SMTP_USERNAME=svc_ad_audit_mail@empresa.local
SMTP_PASSWORD=ALTERAR_PARA_SENHA_FORTE
SMTP_FROM=ad-audit@empresa.local
SMTP_TO=infra@empresa.local,seguranca@empresa.local
SMTP_USE_TLS=true

WEBHOOK_ENABLED=false
WEBHOOK_URL=https://seu-webhook.exemplo.local/ad-audit
WEBHOOK_TOKEN=ALTERAR_PARA_TOKEN_FORTE

GLPI_ENABLED=false
GLPI_URL=https://glpi.empresa.local
GLPI_APP_TOKEN=ALTERAR_PARA_APP_TOKEN
GLPI_USER_TOKEN=ALTERAR_PARA_USER_TOKEN
GLPI_ENTITY_ID=0
GLPI_CREATE_TICKET_ON_CRITICAL=true
GLPI_DEDUP_WINDOW_HOURS=24

ZABBIX_ENABLED=false
ZABBIX_SERVER=zabbix.empresa.local
ZABBIX_HOST=AD-Audit-Portal
ZABBIX_TRAPPER_PORT=10051

PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics

# ==================================================
# PROXY / TLS
# TLS/terminação é feita pelo NGINX Proxy Manager (NPM) externo.
# Mantido aqui apenas para referência/opcional.
# ==================================================
TLS_ENABLED=false

# ==================================================
# NOTIFICAÇÕES E AÇÕES ATIVAS (fora do AD)
# ==================================================
NOTIFICATIONS_ENABLED=true
# Central de Mensagens: domínio de e-mail forçado nos destinatários
NOTIFICATION_EMAIL_DOMAIN=astra-sa.com
BROADCAST_MAX_RECIPIENTS=1000
GOOGLE_CHAT_ENABLED=true
# Mensagem Windows via WinRM (msg). Só envia para hosts na allowlist.
MESSAGE_WINRM_ENABLED=false
MESSAGE_WINRM_ALLOWED_HOSTS=host1.empresa.local,host2.empresa.local
# true = permite enviar msg para QUALQUER host (ignora a allowlist)
MESSAGE_WINRM_ALLOW_ANY_HOST=false
MESSAGE_WINRM_TIMEOUT_SECONDS=10
# Aviso automático de expiração de senha
PASSWORD_EXPIRY_NOTICE_DAYS=14,7,3,1
PASSWORD_EXPIRY_NOTIFICATION_CHANNEL=email
# ChatOps (webhooks)
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# ==================================================
# SEGURANÇA DO PORTAL
# ==================================================
# Perfis que exigem MFA (força cadastro no 1º login). Ex.: administrator,security_analyst
MFA_REQUIRED_ROLES=
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15

# ==================================================
# DETECÇÃO DEFENSIVA
# ==================================================
PASSWORD_SPRAY_ENABLED=true
PASSWORD_SPRAY_WINDOW_MINUTES=15
PASSWORD_SPRAY_MIN_TARGETS=10
KERBEROASTING_DETECTION_ENABLED=true
ASREP_ROASTING_DETECTION_ENABLED=true

# ==================================================
# AUDITORIA INTERNA
# ==================================================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=730
AUDIT_EXPORT_ENABLED=true
AUDIT_RAW_EVENT_ACCESS_SECURITY_ONLY=true
MASK_SENSITIVE_DATA=true

# ==================================================
# PERFORMANCE / POOL / LIMITES (Fase 1)
# ==================================================
API_SQL_POOL_SIZE=10
API_SQL_MAX_OVERFLOW=20
API_SQL_POOL_RECYCLE_SECONDS=1800
API_MAX_PAGE_SIZE=500
API_DEFAULT_EVENT_RANGE_DAYS=7
API_MAX_EVENT_RANGE_DAYS=90

# ==================================================
# MANUTENÇÃO / RETENÇÃO DE BANCO / HARDENING
# ==================================================
# Histórico de entregas de notificações mantido por N dias (purge automático).
NOTIFICATION_RETENTION_DAYS=180
# VACUUM ANALYZE ao final da limpeza (recupera espaço de linhas mortas/bloat).
MAINTENANCE_VACUUM_ENABLED=true
# Hora (0-23) da limpeza automática diária executada pelo worker/beat.
MAINTENANCE_CRON_HOUR=3
# Timeout de statement do Postgres por sessão do app (ms). Evita queries
# travando o banco / sobrecarga. 0 = sem limite (não recomendado em produção).
DB_STATEMENT_TIMEOUT_MS=30000

# ==================================================
# CACHE REDIS
# ==================================================
CACHE_ENABLED=true
CACHE_DASHBOARD_TTL_SECONDS=60
CACHE_ENTITY_TTL_SECONDS=300
CACHE_SEARCH_TTL_SECONDS=120
CACHE_HEALTH_TTL_SECONDS=30
CACHE_STAMPEDE_LOCK_SECONDS=10

# ==================================================
# FEATURE FLAGS
# ==================================================
FEATURE_INCIDENTS_ENABLED=false
FEATURE_PERFORMANCE_DASHBOARD_ENABLED=true
FEATURE_WEBSOCKET_ENABLED=false
FEATURE_PARTITIONING_ENABLED=false

# ==================================================
# RATE LIMITING
# ==================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_LOGIN=10/minute

# ==================================================
# BACKUP
# ==================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups
